    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://YOUR_INFLUXDB_URL/api/v2/write?org=YOUR_ORG&bucket=YOUR_BUCKET",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
