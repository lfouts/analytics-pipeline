      ],
      "id": "546673c1-71af-4764-9665-6c7c0122bbe1",
      "name": "HTTP Request",
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_INFLUXDB_CREDENTIAL_ID",
          "name": "Header Auth account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const newItems = [];\n\nfor (const item of $input.all()) {\n  const country = (item.json.country || 'Unknown')\n    .replace(/ /g, '_')\n    .replace(/[^a-zA-Z0-9_]/g, '');\n  \n  const city = (item.json.city || 'Unknown')\n    .replace(/ /g, '_')\n    .replace(/[^a-zA-Z0-9_]/g, '');\n  \n  newItems.push({\n    json: {\n      ...item.json,\n      country: country,\n      city: city\n    }\n  });\n}\n\nreturn newItems;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
