          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "Text/Plain",
        "body": "=website_stats,date={{ $json.date }},country={{ $json.country }},city={{ $json.city }} sessions={{ $json.sessions }}i,totalUsers={{ $json.totalUsers }}i,pageViews={{ $json.screenPageViews }}i,engagementDuration={{ $json.userEngagementDuration }}i",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        624,
